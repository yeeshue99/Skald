# Neon Postgres connection string.
# Create a free project at https://neon.tech, then copy the connection string
# (it looks like the line below). Use the SAME value locally and on Vercel.
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Optional: enables drag/drop image uploads for tweets and avatars.
# Create a Blob store in your Vercel project (Storage tab) and paste its token.
# Leave blank to fall back to pasting an image URL instead.
BLOB_READ_WRITE_TOKEN=""

# Optional: global (cross-instance) rate limiting via Upstash Redis REST.
# Set both to coordinate the write-path limits across serverless instances.
# Leave unset to use the per-process in-memory limiter (the default). If Upstash
# is set but unreachable at request time the limiter degrades to in-memory.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Optional: generate seeded avatars and post images from each persona's
# avatarHint / post imageHint via an image-gen API. Leave blank to keep the
# deterministic placeholders (DiceBear avatars by handle, picsum by post ref),
# which is the default and identical to before.
IMAGE_GEN_API_KEY=""
# Provider selector (default: openai) and optional model override.
IMAGE_GEN_PROVIDER="openai"
IMAGE_GEN_MODEL="gpt-image-1"
# Note: OpenAI returns base64 images, which are uploaded to Vercel Blob, so
# BLOB_READ_WRITE_TOKEN must also be set for generated images to persist;
# otherwise generation falls back to the placeholder.
